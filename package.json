    "babel-eslint": "^10.0.1",
    "eslint": "^5.3.0",
    "eslint-config-airbnb-base": "^13.1.0",
    "eslint-plugin-import": "^2.18.2",
    "husky": "^3.0.9",
    "lint-staged": "^9.2.5",
    "parcel-bundler": "^1.10.1",
    "parcel-plugin-bundle-visualiser": "^1.2.0",
